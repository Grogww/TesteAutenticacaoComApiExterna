# Credenciais do Google Cloud Console (OAuth 2.0 Client ID)
GOOGLE_CLIENT_ID=seu_client_id_aqui
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Segredo usado para assinar os cookies de sessao (troque por algo aleatorio)
SESSION_SECRET=troque_isto_por_uma_string_aleatoria

# Porta do servidor
PORT=3000

# Opcional: restringir login a um dominio especifico (ex.: ifc.edu.br)
# Deixe em branco para aceitar qualquer dominio.
ALLOWED_EMAIL_DOMAIN=
